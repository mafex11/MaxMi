<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for notarization. MaxMi captures via Accessibility, records
     meeting audio (mic + ScreenCaptureKit), and shells out to osascript (Mail) — so it needs
     the audio-input entitlement and Apple-events automation, and must NOT enable the sandbox
     (Accessibility + arbitrary-app AX reads are incompatible with the App Sandbox; MaxMi ships
     as a Developer-ID/notarized app, not a Mac App Store app). -->
<plist version="1.0">
<dict>
    <!-- microphone capture for meeting recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- MaxMi shells out to osascript to read Mail; Automation (AppleEvents) under hardened runtime -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- whisper.cpp is JIT-free but the vendored C/C++ + dynamic linking is fine without these;
         we deliberately do NOT grant allow-unsigned-executable-memory / disable-library-validation
         unless a load failure proves they're needed (keep the attack surface minimal). -->
</dict>
</plist>
